# Copiá a `keystore.properties` (gitignored) y completá con valores reales.
# NUNCA commitees keystore.properties — las passwords están en texto plano.
#
# storeFile: ruta absoluta al .keystore (el de ~/.android-keystores/ en Mac).
# No usar ~ — Gradle no expande tilde. Usá ruta completa.

storeFile=/Users/devlmer/.android-keystores/pos-chile-release.keystore
storePassword=
keyAlias=pos-chile
keyPassword=
