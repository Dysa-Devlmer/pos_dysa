# ─────────────────────────────────────────────────────────────────────────────
# apps/mobile/.env — Variables de entorno para el POS mobile
#
# Copiar a .env local:
#   cp apps/mobile/.env.example apps/mobile/.env
#
# Reglas:
# - Todas las vars que el CLIENT consume DEBEN tener prefijo EXPO_PUBLIC_
#   (Expo solo inyecta esas al bundle JS; el resto queda solo server-side)
# - .env NO se commitea (está en .gitignore)
# - Para producción (EAS Build), las envs se leen desde eas.json > build.<profile>.env
#   — esta .env local solo aplica a `expo start` en desarrollo
# ─────────────────────────────────────────────────────────────────────────────

# Base URL del backend web (apps/web) — consumida por @repo/api-client
#
# Opciones por escenario:
#   • Dev local con Mac como server:   http://192.168.1.XX:3000  (IP Mac en la LAN)
#   • Dev local emulador Android:      http://10.0.2.2:3000       (mapping automático)
#   • Dev local simulador iOS:         http://localhost:3000
#   • Preview/Production (EAS Build):  https://dy-pos.zgamersa.com
#     (ya está bakeado en eas.json → no hace falta setearlo acá para EAS)
#
# IMPORTANTE: si se deja SIN setear, authStore.ts cae al fallback
# "https://dy-pos.zgamersa.com" — seguro para prod pero RIESGOSO para dev
# (mobile local termina hitting a prod sin darte cuenta).
#
EXPO_PUBLIC_API_URL=http://localhost:3000

# ─── Telemetría (M7+) ────────────────────────────────────────────────────────
# Sentry RN — error tracking + performance
# Obtener DSN desde https://sentry.io/settings/dy-company/projects/pos-chile-mobile/keys/
# (proyecto se crea recién en M7 — hasta entonces dejar vacío: Sentry se auto-desactiva)
EXPO_PUBLIC_SENTRY_DSN=

# PostHog mobile — analytics + feature flags
# Obtener API key desde https://us.posthog.com/project/{id}/settings
# host por default us.i.posthog.com; para self-hosted apuntar al endpoint propio
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
