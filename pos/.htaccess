Options All -Indexes

# ─── Habilitar mod_rewrite ───────────────────────────
RewriteEngine On

# Ajusta RewriteBase según tu entorno:
# XAMPP Windows → /pos/
# MAMP Mac      → /pos/
# Servidor raíz → /
RewriteBase /pos/

# ─── No reescribir archivos/carpetas reales ──────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# ─── Ruta amigable → index.php?ruta=xxx ─────────────
RewriteRule ^([-a-zA-Z0-9]+)$ index.php?ruta=$1 [L,QSA]