generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  CAJERO
  VENDEDOR
}

enum MetodoPago {
  EFECTIVO
  DEBITO
  CREDITO
  TRANSFERENCIA
  MIXTO
}

enum AuditAccion {
  CREATE
  UPDATE
  DELETE
  RESTORE
}

enum TipoMovimientoCaja {
  INGRESO
  EGRESO
  RETIRO
  AJUSTE
}

enum EstadoApertura {
  ABIERTA
  CERRADA
}

model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  nombre    String
  password  String
  rol       Rol      @default(CAJERO)
  activo    Boolean  @default(true)
  avatar    String?  // Data URL base64 (JPEG 200x200 comprimido, ~50-100 KB)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ventas         Venta[]
  ventasBorradas Venta[]      @relation("VentaDeletedBy")
  accounts       Account[]
  sessions       Session[]
  devoluciones   Devolucion[]
  auditLogs      AuditLog[]
  aperturasCaja  AperturaCaja[]
  movimientosCaja MovimientoCaja[]

  @@map("usuarios")
}

model Account {
  id                String  @id @default(cuid())
  userId            Int     @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  usuario Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       Int      @map("user_id")
  expires      DateTime

  usuario Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Categoria {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  descripcion String?
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  productos Producto[]

  @@map("categorias")
}

model Producto {
  id           Int      @id @default(autoincrement())
  nombre       String
  descripcion  String?
  codigoBarras String   @unique @map("codigo_barras")
  precio       Int
  stock        Int      @default(0)
  alertaStock  Int      @default(5) @map("alerta_stock")
  ventas       Int      @default(0)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  categoriaId Int       @map("categoria_id")
  categoria   Categoria @relation(fields: [categoriaId], references: [id])

  detallesVenta   DetalleVenta[]
  devolucionItems DevolucionItem[]

  @@index([categoriaId])
  @@index([codigoBarras])
  @@index([nombre])
  @@map("productos")
}

model Cliente {
  id            Int       @id @default(autoincrement())
  rut           String    @unique
  nombre        String
  email         String?
  telefono      String?
  direccion     String?
  compras       Int       @default(0)
  ultimaCompra  DateTime? @map("ultima_compra")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  ventas Venta[]

  @@index([rut])
  @@map("clientes")
}

model Venta {
  id           Int        @id @default(autoincrement())
  numeroBoleta String     @unique @map("numero_boleta")
  fecha        DateTime   @default(now())
  subtotal       Int
  descuentoPct   Decimal  @default(0) @db.Decimal(5, 2) @map("descuento_pct")
  descuentoMonto Int      @default(0) @map("descuento_monto")
  impuesto       Int
  total          Int
  metodoPago     MetodoPago @default(EFECTIVO) @map("metodo_pago")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  clienteId Int?     @map("cliente_id")
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  usuarioId Int     @map("usuario_id")
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  // Soft-delete (F-3 audit) — los listados activos filtran por deletedAt = null
  deletedAt       DateTime? @map("deleted_at")
  deletedBy       Int?      @map("deleted_by")
  deletionReason  String?   @map("deletion_reason")
  deletedByUsuario Usuario? @relation("VentaDeletedBy", fields: [deletedBy], references: [id], onDelete: SetNull)

  // F-9: Caja con split tender
  // - aperturaId: FK a la AperturaCaja activa al momento de la venta (audit + cierre Z).
  // - montoRecibido / vuelto: solo para componente EFECTIVO del split (suma de pagos
  //   con metodo=EFECTIVO). Null si la venta no incluyó efectivo.
  // - metodoPago se mantiene en la tabla raíz por back-compat con queries existentes
  //   (filtros, reportes, dashboard). Se popula con el método único si pagos.length==1
  //   o con MIXTO si hay >1 método.
  aperturaId     Int?         @map("apertura_id")
  apertura       AperturaCaja? @relation(fields: [aperturaId], references: [id], onDelete: SetNull)
  montoRecibido  Int?         @map("monto_recibido")
  vuelto         Int?

  detalles     DetalleVenta[]
  devoluciones Devolucion[]
  pagos        PagoVenta[]

  @@index([fecha])
  @@index([numeroBoleta])
  @@index([clienteId])
  @@index([usuarioId])
  @@index([deletedAt])
  @@index([aperturaId])
  @@map("ventas")
}

// ─────────────────────────────────────────────────────────────────────
// F-9 — Caja (turnos), movimientos, pagos split-tender
// ─────────────────────────────────────────────────────────────────────

model Caja {
  id        Int      @id @default(autoincrement())
  nombre    String
  ubicacion String?
  activa    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  aperturas AperturaCaja[]

  @@map("cajas")
}

model AperturaCaja {
  id                   Int            @id @default(autoincrement())
  cajaId               Int            @map("caja_id")
  caja                 Caja           @relation(fields: [cajaId], references: [id])
  usuarioId            Int            @map("usuario_id")
  usuario              Usuario        @relation(fields: [usuarioId], references: [id])
  montoInicial         Int            @map("monto_inicial")
  fechaApertura        DateTime       @default(now()) @map("fecha_apertura")
  fechaCierre          DateTime?      @map("fecha_cierre")
  montoFinalDeclarado  Int?           @map("monto_final_declarado")
  montoFinalSistema    Int?           @map("monto_final_sistema")
  diferencia           Int?
  observaciones        String?
  estado               EstadoApertura @default(ABIERTA)

  ventas       Venta[]
  movimientos  MovimientoCaja[]

  @@index([cajaId])
  @@index([usuarioId])
  @@index([estado])
  @@map("aperturas_caja")
}

model MovimientoCaja {
  id          Int                 @id @default(autoincrement())
  aperturaId  Int                 @map("apertura_id")
  apertura    AperturaCaja        @relation(fields: [aperturaId], references: [id], onDelete: Cascade)
  tipo        TipoMovimientoCaja
  monto       Int
  motivo      String
  usuarioId   Int                 @map("usuario_id")
  usuario     Usuario             @relation(fields: [usuarioId], references: [id])
  fecha       DateTime            @default(now())

  @@index([aperturaId])
  @@index([fecha])
  @@map("movimientos_caja")
}

model PagoVenta {
  id         Int        @id @default(autoincrement())
  ventaId    Int        @map("venta_id")
  venta      Venta      @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  metodo     MetodoPago
  monto      Int
  referencia String?

  @@index([ventaId])
  @@map("pagos_venta")
}

// ─────────────────────────────────────────────────────────────────────
// AuditLog (F-3) — bitácora de operaciones sensibles sobre ventas y otros
// recursos. Todo soft-delete y restore inserta una fila aquí.
// `diff` opcional almacena snapshot del registro o subset relevante (ej.
// detalles de la venta al borrar) en JSON para poder reconstruir la
// situación previa si la auditoría lo requiere.
// ─────────────────────────────────────────────────────────────────────

model AuditLog {
  id         Int          @id @default(autoincrement())
  tabla      String
  registroId Int          @map("registro_id")
  accion     AuditAccion
  usuarioId  Int          @map("usuario_id")
  diff       Json?
  fecha      DateTime     @default(now())
  ip         String?
  userAgent  String?      @map("user_agent")

  usuario    Usuario      @relation(fields: [usuarioId], references: [id])

  @@index([tabla, registroId])
  @@index([fecha])
  @@map("audit_logs")
}

model DetalleVenta {
  id             Int @id @default(autoincrement())
  cantidad       Int
  precioUnitario Int @map("precio_unitario")
  subtotal       Int

  ventaId    Int      @map("venta_id")
  venta      Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  productoId Int      @map("producto_id")
  producto   Producto @relation(fields: [productoId], references: [id])

  @@index([ventaId])
  @@index([productoId])
  @@map("detalle_ventas")
}

model Devolucion {
  id            Int      @id @default(autoincrement())
  ventaId       Int      @map("venta_id")
  venta         Venta    @relation(fields: [ventaId], references: [id])
  fecha         DateTime @default(now())
  motivo        String   @db.VarChar(255)
  montoDevuelto Int      @map("monto_devuelto")
  esTotal       Boolean  @default(false) @map("es_total")

  creadoPor Int     @map("creado_por")
  usuario   Usuario @relation(fields: [creadoPor], references: [id])

  items DevolucionItem[]

  @@index([ventaId])
  @@index([fecha])
  @@index([creadoPor])
  @@map("devoluciones")
}

model DevolucionItem {
  id             Int        @id @default(autoincrement())
  devolucionId   Int        @map("devolucion_id")
  devolucion     Devolucion @relation(fields: [devolucionId], references: [id], onDelete: Cascade)
  productoId     Int        @map("producto_id")
  producto       Producto   @relation(fields: [productoId], references: [id])
  cantidad       Int
  precioUnitario Int        @map("precio_unitario")
  subtotal       Int

  @@index([devolucionId])
  @@index([productoId])
  @@map("devolucion_items")
}

// ─────────────────────────────────────────────────────────────────────
// Mobile release management (M7)
//
// Cada publicación de APK crea un MobileRelease. El endpoint público
// `GET /api/mobile/manifest` devuelve el que tiene `isLatest = true` para
// la plataforma solicitada. La app mobile hace polling al abrir y muestra
// banner "Actualizar" si la versión instalada es menor que la remota.
//
// Campo `minVersion` → si la versión instalada es MENOR a este valor, el
// banner es `forceUpdate: true` (no se puede dismissar). Útil para
// bugfixes de seguridad que no pueden esperar opt-in del usuario.
//
// Convención: SOLO UNO debe tener `isLatest = true` por plataforma a la
// vez. El POST del endpoint hace el toggle atómico vía $transaction.
// ─────────────────────────────────────────────────────────────────────

enum MobilePlatform {
  ANDROID
  IOS
}

model MobileRelease {
  id          String          @id @default(cuid())
  platform    MobilePlatform  @default(ANDROID)
  version     String          // semver: "1.0.0"
  versionCode Int             // android versionCode: 1, 2, 3... (ios: buildNumber)
  apkUrl      String          @map("apk_url")     // Cloudflare R2 URL pública
  notes       String?         @db.Text            // changelog visible al usuario
  minVersion  String?         @map("min_version") // forceUpdate si installed < minVersion
  isLatest    Boolean         @default(false) @map("is_latest")
  publishedAt DateTime        @default(now()) @map("published_at")
  publishedBy Int?            @map("published_by") // usuario.id del admin que publicó

  @@unique([platform, version])
  @@unique([platform, versionCode])
  @@index([platform, isLatest])
  @@map("mobile_releases")
}
