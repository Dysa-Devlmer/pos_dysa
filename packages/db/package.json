{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env -o -- prisma db push",
    "db:migrate": "dotenv -e .env -o -- prisma migrate dev",
    "db:studio": "dotenv -e .env -o -- prisma studio",
    "db:seed": "dotenv -e .env -o -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.6.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3"
  }
}
