# ─────────────────────────────────────────────────────────────────────
# Android / mobile signing — defense-in-depth
# Keystore release vive en ~/.android-keystores/, FUERA del repo.
# Estos globs son paranoia contra un mv/cp accidental al repo.
# ─────────────────────────────────────────────────────────────────────
*.keystore
*.jks
credentials.json
keystore.properties
.env.mobile.local
.env.mobile.publish
android.env

# APK artifacts — los subimos a Cloudflare R2, no al repo (40-80 MB cada uno)
releases/*.apk
apps/mobile/releases/

# Android build artifacts — generados por gradle, no trackear
apps/mobile/android/.gradle/
apps/mobile/android/build/
apps/mobile/android/app/build/
apps/mobile/android/local.properties

# Mobile web export (expo export -p web) — canvaskit.wasm + bundle, no commitear
apps/mobile/web/

# Imagenes generadas Gemini sin uso en codigo (audit R-refactor #3)
img-nano/
