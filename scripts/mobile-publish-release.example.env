# Plantilla para mobile-publish-release.sh
#
# 1. Copiá este archivo a `.env.mobile.publish` (en la raíz del repo, gitignored)
# 2. Completá los valores reales
# 3. NUNCA commitees `.env.mobile.publish` — está en .gitignore
#
# Para rotar el token R2: Cloudflare dashboard → My Profile → API Tokens → Roll

# Cloudflare R2 — bucket público con los APKs
CLOUDFLARE_ACCOUNT_ID=fa2fd1592fea9c324d39fe5d765d9cd5
CLOUDFLARE_API_TOKEN=cfut_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=pos-chile-mobile-releases
# URL pública del bucket (r2.dev o custom domain). SIN trailing slash.
R2_PUBLIC_URL=https://pub-f8234d800bb54f6b9f6d4152b7adca6d.r2.dev

# Backend — endpoint donde POSTear el manifest después de subir el APK
API_BASE_URL=https://dy-pos.zgamersa.com
# Bearer token de un usuario ADMIN (generable con /api/v1/auth/token o reusando sesión)
# Si está vacío, el script te pide que lo pegues interactivo.
ADMIN_API_TOKEN=

# Keystore (para builds locales sin EAS)
KEYSTORE_PATH=$HOME/.android-keystores/pos-chile-release.keystore
KEYSTORE_ALIAS=pos-chile
# Las passwords NO se escriben aquí — el script las pide interactivo y las lee de stdin
