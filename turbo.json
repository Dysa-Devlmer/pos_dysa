{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["**/.env.*local", "**/.env", "tsconfig.json"],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "POS_DATABASE_URL",
    "NEXTAUTH_SECRET",
    "AUTH_SECRET",
    "NEXTAUTH_URL",
    "NEXT_PUBLIC_URL",
    "NEXT_PUBLIC_SENTRY_DSN",
    "SENTRY_DSN",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "PII_LOG_SALT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/*.md",
        "!**/*.test.{ts,tsx}",
        "!**/__tests__/**"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^db:generate"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": [
        "**/*.{ts,tsx,js,jsx,mjs,cjs}",
        "package.json",
        "eslint.config.{js,mjs,cjs,ts}",
        ".eslintrc*",
        ".eslintignore"
      ],
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^db:generate"],
      "inputs": [
        "**/*.{ts,tsx}",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^db:generate"],
      "inputs": [
        "**/*.{ts,tsx,js,jsx}",
        "package.json",
        "vitest.config.*",
        "jest.config.*"
      ],
      "outputs": ["coverage/**"]
    },
    "db:generate": {
      "inputs": ["prisma/schema.prisma"],
      "outputs": ["node_modules/.prisma/**", "node_modules/@prisma/client/**"],
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}
