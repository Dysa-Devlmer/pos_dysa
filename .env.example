# PostgreSQL (docker-compose)
POSTGRES_USER=pos_admin
POSTGRES_PASSWORD=CAMBIAR_password_seguro
POSTGRES_DB=pos_chile_db

# Conexión base de datos — usada por Prisma + Next.js
# IMPORTANTE: POS_DATABASE_URL tiene prioridad sobre DATABASE_URL
POS_DATABASE_URL="postgresql://pos_admin:CAMBIAR@localhost:5432/pos_chile_db?schema=public"

# NextAuth.js — OBLIGATORIO generar con: openssl rand -base64 32
# NUNCA usar el valor por defecto en producción (contiene "cambiar")
# NEXTAUTH_SECRET es el nombre histórico (v4); AUTH_SECRET es el nombre
# canónico v5. El código acepta ambos como fallback (`_helpers.ts:35`,
# `check-env.ts:30`) pero por compatibilidad seguimos exponiendo
# NEXTAUTH_SECRET como obligatoria.
NEXTAUTH_SECRET=CAMBIAR_generar_con_openssl
# AUTH_SECRET — alias v5 opcional. Solo necesaria si migrás 100% a la
# nomenclatura nueva y eliminás NEXTAUTH_SECRET del entorno.
# AUTH_SECRET=CAMBIAR_generar_con_openssl
NEXTAUTH_URL=http://localhost:3000

# URL pública del sitio — usada en sitemap.ts, robots.ts, layout.tsx
# para metadata canónica + Open Graph. En dev podés dejar localhost;
# en prod debe ser la URL real con HTTPS (sin slash final).
NEXT_PUBLIC_URL=http://localhost:3000

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@tu-dominio.cl
PGADMIN_DEFAULT_PASSWORD=CAMBIAR_pgadmin_password

# Upstash Redis (rate limiting) — https://upstash.com
# Crear cuenta gratuita, copiar REST URL y TOKEN
# Si se deja vacío, el rate limiting se desactiva (útil en dev)
UPSTASH_REDIS_REST_URL=https://YOUR_URL.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# Sentry (error tracking + audit logs) — https://sentry.io
# Si se deja vacío, Sentry se auto-desactiva (no-op, no crashea).
# Instrumenta login_failure, login_rate_limited, errores globales.
SENTRY_DSN=

# Sentry client-side — leída por sentry.client.config.ts. Puede ser el
# mismo DSN que SENTRY_DSN (ambos apuntan al mismo proyecto Sentry) o
# uno separado si querés separar errores de browser vs server. Si está
# vacía, el cliente Sentry se desactiva (no envía eventos del browser).
NEXT_PUBLIC_SENTRY_DSN=

# Privacy / PII pseudonymization — OBLIGATORIO en producción
# Usado por apps/web/lib/privacy.ts:pseudonymize() para hashear RUT/email/etc
# antes de enviar a Sentry, PostHog, logs.
# Generar con: openssl rand -base64 32
# Rotar anualmente (o tras cualquier breach). Al rotar, los hashes anteriores
# pierden correlación — aceptable por defensa-en-profundidad.
# En dev (NODE_ENV != production) si falta se usa fallback determinístico.
PII_LOG_SALT=CAMBIAR_generar_con_openssl
